{
  "name": "@prism/signaling",
  "version": "1.0.0",
  "private": true,
  "description": "Prism signaling server (WebRTC mesh)",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist *.tsbuildinfo",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:security": "vitest run --reporter=verbose test/security",
    "test:watch": "vitest watch"
  },
  "license": "MIT",
  "dependencies": {
    "@prism/protocol": "^1.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
