# Web UI (build-time — used by Vite when building apps/web)
# Leave empty for same-origin deployment (Docker Compose default).
# Set to a full URL only if the UI is served from a different origin than the API.
# Example: VITE_SIGNALING_URL=https://api.yourdomain.com
VITE_SIGNALING_URL=

# Debug panel (build-time — shows ICE/connection diagnostics in the UI)
VITE_DEBUG_ENABLED=false

# Signaling server
PORT=3000
NODE_ENV=production

# CORS — comma-separated list of allowed origins (no wildcards with credentials)
SIGNALING_ALLOWED_ORIGINS=https://yourdomain.com

# Room limits
MAX_PEERS_PER_ROOM=8
MAX_GLOBAL_PEERS=100
ROOM_TTL_MS=3600000

# Rate limits (per IP, requests per window)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# ICE / TURN
# IMPORTANT: Use a publicly routable IP or hostname, not a LAN address (10.x, 192.168.x).
# External browsers must reach these endpoints directly over UDP/TCP.
# Find your public IP with: curl -s ifconfig.me
STUN_URLS=stun:your-public-ip-or-hostname:3478
TURN_URLS=turn:your-public-ip-or-hostname:3478
TURN_USERNAME=
TURN_CREDENTIAL=
# Short-lived credentials (recommended): set TURN_SECRET to match coturn's static-auth-secret.
# Leave TURN_USERNAME and TURN_CREDENTIAL empty when using TURN_SECRET.
TURN_SECRET=

# Metrics (optional — set to "true" to enable GET /metrics)
METRICS_ENABLED=false
METRICS_BEARER_TOKEN=
